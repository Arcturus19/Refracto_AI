# PostgreSQL Configuration
POSTGRES_USER=change_me_postgres_user
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=refracto_ai_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@refracto.ai
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin_password

# Database URL for services
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# JWT Configuration (CHANGE THIS IN PRODUCTION!)
SECRET_KEY=replace_with_a_long_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ACCESS_COOKIE_NAME=access_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
CORS_ORIGINS=http://localhost:5173
INTERNAL_API_TOKEN=replace_with_a_random_internal_service_token

# ML ↔ Patient service integration (optional overrides)
# In docker-compose, the default resolves via service name `patient_service`.
PATIENT_SERVICE_URL=http://patient_service:8000

# Imaging access enforcement
# off | required
ACCESS_ENFORCEMENT_MODE=required

# ML consent enforcement
# off | if_patient_provided | required
CONSENT_ENFORCEMENT_MODE=if_patient_provided
CONSENT_TYPE=ml_analysis

# ML tamper-evident audit log (JSONL hash chain)
AUDIT_LOG_PATH=/data/audit/ml_predictions_audit.jsonl
AUDIT_HASH_SALT=replace_with_a_random_audit_salt

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=replace_with_minio_user
MINIO_ROOT_PASSWORD=replace_with_minio_password
MINIO_SECURE=false

